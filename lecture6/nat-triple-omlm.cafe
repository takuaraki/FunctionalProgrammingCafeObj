mod! NAT-TRIPLE-OMLM { 
  pr(NAT)
  [NatTriple]
  op (_,_,_) : Nat Nat Nat -> NatTriple {constr} .
  op 1st : NatTriple -> Nat {strat: (0 1 0)} .
  vars FE SE TE : Nat .
  eq 1st((FE,SE,TE)) = FE .
}

set trace whole on
open NAT-TRIPLE-OMLM .
  red 1st((1 + 1,2 + 2,3 + 3)) .
close
set trace whole off