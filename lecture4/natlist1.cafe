-- インスタンス化の方法１：viewをあらかじめ定義する

-- TRIVモジュールのソートEltは、NATモジュールのソートNatで置き換えられる
view TRIV2NAT from TRIV to NAT {
  sort Elt -> Nat,
}

mod! NATLIST1 {
  -- TRIVを満たすモジュールEは、NATモジュールに置き換えられる
  -- EのソートEltはNATモジュールのソートNatに置き換えられる
  pr(GLIST1(E <= TRIV2NAT))
}

open NATLIST1 .
  red (4 | 3 | nil) @ (2 | 1 | 0 | nil) .
close
