mod! GLIST1(E :: TRIV) { -- EはTRIV(ソートを1つだけ持つ)を満たすモジュール. GLIST1のパラメータ
  [Nil NnList < List]

  op nil : -> Nil {constr}
  op _|_ : Elt.E List -> NnList {constr} -- Elt.EはモジュールEで定義されるソート. パラメータが2つ以上ある場合、Eの部分で区別できる
  op _@_ : List List -> List

  var X : Elt.E
  vars L L2 : List

  eq nil @ L2 = L2 .
  eq (X | L) @ L2 = X | (L @ L2) .
}
