view TRIV-ERR2NAT-ERR from TRIV-ERR to NAT-ERR {
  sort Elt -> Nat,
  sort Err -> ErrNat,
  sort Elt&Err -> Nat&Err,
  op err -> errNat,
}

mod! NATLIST7 {
  pr(GLIST2(E <= TRIV-ERR2NAT-ERR) * {
    sort List -> NatList,
    sort Nil -> NLNil,
    sort NnList -> NnNatList,
    op nil -> nlnil
  })
}

open NATLIST7 .
  red hd(nlnil) .
  red hd((4 | 3 | nlnil) @ (2 | 1 | 0 | nlnil)) .
  red tl(nlnil) .
  red tl((4 | 3 | nlnil) @ (2 | 1 | 0 | nlnil)) .
close
